<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Panel -->
    <Color x:Key="PanelBackgroundColor">#F7F8F9FC</Color>
    <SolidColorBrush x:Key="PanelBackground" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#14000000" />
    <SolidColorBrush x:Key="HandleBrush" Color="#1A000000" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#0D000000" />

    <!-- Cards -->
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardBorder" Color="#12000000" />
    <SolidColorBrush x:Key="CardHoverBorder" Color="#20000000" />
    <SolidColorBrush x:Key="CardSelectedBorder" Color="#30000000" />
    <SolidColorBrush x:Key="CardSelectedFooterBackground" Color="#1A4F46E5" />

    <!-- Search -->
    <SolidColorBrush x:Key="SearchBackground" Color="#0D000000" />
    <SolidColorBrush x:Key="SearchBorder" Color="#12000000" />
    <SolidColorBrush x:Key="SearchPlaceholder" Color="#9CA3AF" />

    <!-- Chips -->
    <SolidColorBrush x:Key="ChipIdleBackground" Color="#0F000000" />
    <SolidColorBrush x:Key="ChipIdleForeground" Color="#6B7280" />
    <SolidColorBrush x:Key="ChipActiveBackground" Color="#4F46E5" />
    <SolidColorBrush x:Key="ChipActiveForeground" Color="#FFFFFF" />

    <!-- Typography -->
    <SolidColorBrush x:Key="AppNameForeground" Color="#374151" />
    <SolidColorBrush x:Key="BodyText" Color="#374151" />
    <SolidColorBrush x:Key="MetaText" Color="#9CA3AF" />
    <SolidColorBrush x:Key="HeaderText" Color="#111827" />
    <SolidColorBrush x:Key="SearchIcon" Color="#9CA3AF" />

    <!-- Code block -->
    <SolidColorBrush x:Key="CodeBackground" Color="#F0F7FF" />
    <SolidColorBrush x:Key="CodeForeground" Color="#1E40AF" />

    <!-- Footer -->
    <SolidColorBrush x:Key="FooterBackground" Color="#04000000" />
    <SolidColorBrush x:Key="FooterBorder" Color="#0D000000" />
    <SolidColorBrush x:Key="FooterHoverBackground" Color="#0D4F46E5" />
    <SolidColorBrush x:Key="FooterHoverBorder" Color="#1A4F46E5" />

    <!-- Keyboard hints -->
    <SolidColorBrush x:Key="KbdBackground" Color="#0A000000" />
    <SolidColorBrush x:Key="KbdBorder" Color="#14000000" />
    <SolidColorBrush x:Key="KbdForeground" Color="#6B7280" />
    <SolidColorBrush x:Key="KbdHintForeground" Color="#9CA3AF" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#4F46E5" />
    <SolidColorBrush x:Key="AccentSecondary" Color="#6366F1" />
    <SolidColorBrush x:Key="PasteActionForeground" Color="#4F46E5" />
    <SolidColorBrush x:Key="CopyActionForeground" Color="#6B7280" />
    <SolidColorBrush x:Key="DeleteActionForeground" Color="#DC2626" />
    <SolidColorBrush x:Key="PinActiveForeground" Color="#4F46E5" />
    <SolidColorBrush x:Key="PinInactiveForeground" Color="#D1D5DB" />

    <!-- Scroll arrows -->
    <SolidColorBrush x:Key="ScrollArrowBackground" Color="#1A000000" />
    <SolidColorBrush x:Key="ScrollArrowForeground" Color="#9CA3AF" />

    <!-- Settings window -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SectionHeaderForeground" Color="#6B7280" />
    <SolidColorBrush x:Key="SettingRowBackground" Color="#FAFAFA" />
    <SolidColorBrush x:Key="SettingLabelForeground" Color="#111827" />
    <SolidColorBrush x:Key="SettingSubLabelForeground" Color="#6B7280" />
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorder" Color="#E5E7EB" />
    <SolidColorBrush x:Key="InputForeground" Color="#111827" />
    <SolidColorBrush x:Key="ButtonBackground" Color="#F9FAFB" />
    <SolidColorBrush x:Key="ButtonBorder" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#374151" />
    <SolidColorBrush x:Key="DestructiveBackground" Color="#FEF2F2" />
    <SolidColorBrush x:Key="DestructiveBorder" Color="#FECACA" />
    <SolidColorBrush x:Key="DestructiveForeground" Color="#DC2626" />
    <SolidColorBrush x:Key="PrivacyNoteBackground" Color="#F0FDF4" />
    <SolidColorBrush x:Key="PrivacyNoteBorder" Color="#BBF7D0" />
    <SolidColorBrush x:Key="PrivacyNoteForeground" Color="#166534" />
</ResourceDictionary>
