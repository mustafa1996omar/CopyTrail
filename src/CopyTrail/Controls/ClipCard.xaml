<UserControl x:Class="CopyTrail.Controls.ClipCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CopyTrail.Controls"
             xmlns:converters="clr-namespace:CopyTrail.Converters"
             Width="168" Cursor="Hand"
             MouseEnter="Card_MouseEnter"
             MouseLeave="Card_MouseLeave"
             MouseLeftButtonUp="Card_Click"
             Loaded="Card_Loaded">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border x:Name="CardBorder"
            CornerRadius="11"
            BorderThickness="1.5"
            Background="{DynamicResource CardBackground}">

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                          Opacity="0.06" Color="#000000" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource CardSelectedBorder}" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                                                  Opacity="0.25" Color="#000000" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="72" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- ── Band ── -->
            <Border Grid.Row="0" CornerRadius="11,11,0,0"
                    x:Name="BandBorder"
                    Background="{Binding SoftAccentBrush}">
                <Grid Margin="10,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <controls:SourceBadge Grid.Column="0"
                                          Source="{Binding Source}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding Source.AppName}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding AccentBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <Border Grid.Column="2"
                            Background="{Binding BadgeBackgroundBrush}"
                            CornerRadius="5" Padding="6,2,6,2">
                        <TextBlock Text="{Binding ContentKind}"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="{Binding BadgeForegroundBrush}" />
                    </Border>
                </Grid>
            </Border>

            <!-- ── Body ── -->
            <Grid Grid.Row="1">

                <!-- Image -->
                <Border Padding="8,6,8,4"
                        Visibility="{Binding IsImageCard, Converter={StaticResource BoolToVis}}">
                    <Image Source="{Binding ThumbnailPath}"
                           MaxHeight="60" Stretch="Uniform"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <!-- Code -->
                <Border Padding="0"
                        Visibility="{Binding IsCodeCard, Converter={StaticResource BoolToVis}}">
                    <Border Background="{DynamicResource CodeBackground}" Margin="8,6,8,4"
                            CornerRadius="5" Padding="7,6">
                        <TextBlock Text="{Binding Preview}"
                                   FontFamily="Cascadia Code, Consolas, Courier New, monospace"
                                   FontSize="10" LineHeight="15"
                                   Foreground="{DynamicResource CodeForeground}"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxHeight="62" />
                    </Border>
                </Border>

                <!-- Color swatch -->
                <Border Padding="10,8,8,6"
                        Visibility="{Binding IsColorCard, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Border Width="90" Height="36" CornerRadius="7"
                                Background="{Binding ColorSwatchBrush}"
                                HorizontalAlignment="Left" Margin="0,0,0,6"
                                BorderThickness="1" BorderBrush="{DynamicResource CardBorder}" />
                        <TextBlock Text="{Binding Preview}" FontSize="11"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   Foreground="{DynamicResource BodyText}" />
                    </StackPanel>
                </Border>

                <!-- URL -->
                <Border Padding="10,8,8,4"
                        Visibility="{Binding IsUrlCard, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding UrlDomain}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{Binding AccentBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding Preview}"
                                   FontSize="10" FontFamily="Cascadia Code, Consolas, monospace"
                                   Foreground="{DynamicResource MetaText}"
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                   MaxHeight="44" />
                    </StackPanel>
                </Border>

                <!-- Default text (shown when none of the above) -->
                <Border Padding="10,8,8,4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsImageCard}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCodeCard}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsColorCard}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUrlCard}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Preview}" FontSize="11"
                               Foreground="{DynamicResource BodyText}"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                               LineHeight="16" MaxHeight="62" />
                </Border>

            </Grid>

            <!-- ── Default footer ── -->
            <Border x:Name="DefaultFooter"
                    Grid.Row="2" CornerRadius="0,0,11,11"
                    Background="{DynamicResource FooterBackground}"
                    BorderBrush="{DynamicResource FooterBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="10,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding CopiedAt}"
                               FontSize="10" VerticalAlignment="Center"
                               Foreground="{DynamicResource MetaText}"
                               ToolTip="{Binding CopiedAtAbsolute}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PinButton" Content="⚑" FontSize="12"
                                Background="Transparent" BorderThickness="0"
                                Padding="3,0" Cursor="Hand"
                                Click="PinButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource PinInactiveForeground}" />
                                    <Setter Property="ToolTip" Value="Pin" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource PinActiveForeground}" />
                                            <Setter Property="ToolTip" Value="Unpin" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="⋯" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource MetaText}"
                                Padding="3,0" Cursor="Hand"
                                Click="MenuButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Hover footer ── -->
            <Border x:Name="HoverFooter"
                    Grid.Row="2" CornerRadius="0,0,11,11"
                    Background="{DynamicResource FooterHoverBackground}"
                    BorderBrush="{Binding AccentBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="PasteBtn" Content="↵ Paste"
                            FontSize="11" FontWeight="SemiBold"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource PasteActionForeground}"
                            Padding="4,3" Cursor="Hand"
                            ToolTip="Paste this item"
                            Click="PasteBtn_Click" />
                    <Button Grid.Column="1" x:Name="CopyBtn" Content="⎘ Copy"
                            FontSize="11" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource CopyActionForeground}"
                            Padding="4,3" Cursor="Hand"
                            ToolTip="Copy without pasting"
                            Click="CopyBtn_Click" />
                    <Button Grid.Column="3" x:Name="DeleteBtn" Content="🗑"
                            FontSize="11" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource MetaText}"
                            Padding="4,3" Cursor="Hand"
                            ToolTip="Delete"
                            Click="DeleteBtn_Click"
                            MouseEnter="DeleteBtn_MouseEnter"
                            MouseLeave="DeleteBtn_MouseLeave" />
                </Grid>
            </Border>

            <!-- ── Selected footer ── -->
            <Border x:Name="SelectedFooter"
                    Grid.Row="2" CornerRadius="0,0,11,11"
                    Background="{DynamicResource CardSelectedFooterBackground}"
                    BorderBrush="{Binding AccentBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="8,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="↵ Enter to paste"
                               FontSize="10.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentSecondary}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="Ctrl+Enter copy"
                               FontSize="10" Foreground="{DynamicResource MetaText}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ── Delete confirm footer ── -->
            <Border x:Name="DeleteConfirmFooter"
                    Grid.Row="2" CornerRadius="0,0,11,11"
                    Background="#CC1C1C1C"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#40EF4444"
                    Padding="8,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Delete?"
                               FontSize="10.5" FontWeight="SemiBold"
                               Foreground="#EF4444"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Yes"
                            FontSize="10.5" FontWeight="SemiBold"
                            Background="#3FEF4444" BorderThickness="0"
                            Foreground="#EF4444" Padding="7,3"
                            Cursor="Hand" Click="DeleteConfirmYes_Click" />
                    <Button Grid.Column="2" Content="No"
                            FontSize="10.5" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource MetaText}" Padding="5,3"
                            Cursor="Hand" Click="DeleteConfirmNo_Click" />
                </Grid>
            </Border>

            <!-- Pin dot (top-right) -->
            <Ellipse Width="6" Height="6"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,8,8,0"
                     Fill="{DynamicResource AccentPrimary}"
                     Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />

        </Grid>
    </Border>

    <UserControl.RenderTransform>
        <TranslateTransform x:Name="CardLiftTransform" Y="0" />
    </UserControl.RenderTransform>
</UserControl>
