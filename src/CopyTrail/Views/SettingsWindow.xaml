<Window x:Class="CopyTrail.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CopyTrail.ViewModels"
        Title="CopyTrail Settings"
        Icon="pack://application:,,,/Resources/Icons/AppIcon.png"
        Width="560"
        SizeToContent="Height"
        MaxHeight="780"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Toggle switch ControlTemplate -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    CornerRadius="12"
                                    Background="#D1D5DB">
                                <Ellipse x:Name="Thumb"
                                         Width="18" Height="18"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4"
                                                          ShadowDepth="1"
                                                          Opacity="0.25"
                                                          Color="#000000" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header label -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SectionHeaderForeground}" />
            <Setter Property="Margin" Value="0,20,0,8" />
        </Style>

        <!-- Row container inside a section -->
        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,13,16,13" />
            <Setter Property="Background" Value="{DynamicResource SettingRowBackground}" />
            <Setter Property="BorderBrush" Value="#F1F5F9" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <!-- Last row — no bottom border -->
        <Style x:Key="SettingRowLastStyle" TargetType="Border">
            <Setter Property="Padding" Value="16,13,16,13" />
            <Setter Property="Background" Value="{DynamicResource SettingRowBackground}" />
        </Style>

        <!-- Setting label -->
        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Foreground" Value="{DynamicResource SettingLabelForeground}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Setting sub-label -->
        <Style x:Key="SettingSubLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Foreground" Value="{DynamicResource SettingSubLabelForeground}" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Value badge (read-only value display) -->
        <Style x:Key="ValueBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,4,10,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Slider style (minimal track) -->
        <Style x:Key="SettingSliderStyle" TargetType="Slider">
            <Setter Property="Width" Value="140" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
        </Style>

        <!-- Action button (destructive-neutral) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8,14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Destructive action button (Clear history) -->
        <Style x:Key="DestructiveButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#FECACA" />
            <Setter Property="Background" Value="#FEF2F2" />
        </Style>

        <!-- Primary button (Save) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,8,20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1D4ED8" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Number TextBox -->
        <Style x:Key="NumberBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4,8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exclusion entry TextBox -->
        <Style x:Key="ExclusionEntryBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4,8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root: transparent with margin for shadow bleed -->
    <Grid Margin="26">
        <Border CornerRadius="16"
                Background="{DynamicResource WindowBackground}"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="48"
                                  Direction="270"
                                  ShadowDepth="12"
                                  Opacity="0.18"
                                  Color="#0F172A" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="62" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Scrollable content -->
                    <RowDefinition Height="*" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Footer -->
                    <RowDefinition Height="60" />
                </Grid.RowDefinitions>

                <!-- ── Header ── -->
                <Grid Grid.Row="0" Margin="20,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="#2563EB" VerticalAlignment="Center">
                            <TextBlock Text="CT"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Settings"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="32" Height="32"
                            VerticalAlignment="Center"
                            Click="CloseButton_Click"
                            ToolTip="Close"
                            FocusVisualStyle="{x:Null}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <TextBlock Text="✕"
                                               FontSize="13"
                                               Foreground="#9CA3AF"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Header separator -->
                <Rectangle Grid.Row="1" Fill="#F1F5F9" />

                <!-- ── Scrollable body ── -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,4,24,16">

                        <!-- ── APPEARANCE ── -->
                        <TextBlock Text="APPEARANCE"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="{DynamicResource InputBorder}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Border Style="{StaticResource SettingRowLastStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Theme"
                                                   Style="{StaticResource SettingLabelStyle}" />
                                        <TextBlock Text="System follows your Windows appearance setting"
                                                   Style="{StaticResource SettingSubLabelStyle}" />
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              x:Name="ThemeComboBox"
                                              Width="110"
                                              SelectedIndex="0"
                                              VerticalAlignment="Center"
                                              SelectionChanged="ThemeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="System" />
                                        <ComboBoxItem Content="Dark" />
                                        <ComboBoxItem Content="Light" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- ── KEYBOARD SHORTCUT ── -->
                        <TextBlock Text="KEYBOARD SHORTCUT"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Border Style="{StaticResource SettingRowLastStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Open popup shortcut"
                                                   Style="{StaticResource SettingLabelStyle}" />
                                        <TextBlock Text="Customizable shortcut recording — coming in V2"
                                                   Style="{StaticResource SettingSubLabelStyle}" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}">
                                        <TextBlock Text="{Binding OpenPopupShortcut}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#374151" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- ── GENERAL ── -->
                        <TextBlock Text="GENERAL"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <StackPanel>
                                <!-- Start with Windows -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Start with Windows"
                                                   Style="{StaticResource SettingLabelStyle}" />
                                        <ToggleButton Grid.Column="1"
                                                      x:Name="StartupToggle"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      IsChecked="{Binding StartWithWindows}" />
                                    </Grid>
                                </Border>
                                <!-- Store images -->
                                <Border Style="{StaticResource SettingRowLastStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Store images"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Save screenshot and image clipboard entries"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      IsChecked="{Binding StoreImages}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── STORAGE LIMITS ── -->
                        <TextBlock Text="STORAGE LIMITS"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <StackPanel>
                                <!-- Max text size -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Max text size"
                                                   Style="{StaticResource SettingLabelStyle}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Slider x:Name="MaxTextSlider"
                                                    Style="{StaticResource SettingSliderStyle}"
                                                    Minimum="1" Maximum="100"
                                                    Value="{Binding MaxTextMb}"
                                                    Margin="0,0,10,0" />
                                            <Border Style="{StaticResource ValueBadgeStyle}" MinWidth="52">
                                                <TextBlock FontSize="12.5" FontWeight="Medium"
                                                           Foreground="#374151"
                                                           HorizontalAlignment="Center">
                                                    <Run Text="{Binding MaxTextMb}" /><Run Text=" MB" />
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <!-- Max image size -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Max image size"
                                                   Style="{StaticResource SettingLabelStyle}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Slider x:Name="MaxImageSlider"
                                                    Style="{StaticResource SettingSliderStyle}"
                                                    Minimum="1" Maximum="200"
                                                    Value="{Binding MaxImageMb}"
                                                    Margin="0,0,10,0" />
                                            <Border Style="{StaticResource ValueBadgeStyle}" MinWidth="52">
                                                <TextBlock FontSize="12.5" FontWeight="Medium"
                                                           Foreground="#374151"
                                                           HorizontalAlignment="Center">
                                                    <Run Text="{Binding MaxImageMb}" /><Run Text=" MB" />
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <!-- Max history count -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Max history items"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Oldest unpinned items are removed when limit is reached"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <TextBox Grid.Column="1"
                                                 x:Name="MaxHistoryBox"
                                                 Style="{StaticResource NumberBoxStyle}"
                                                 Text="{Binding MaxHistoryCount, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewTextInput="MaxHistoryBox_PreviewTextInput" />
                                    </Grid>
                                </Border>
                                <!-- Max total storage -->
                                <Border Style="{StaticResource SettingRowLastStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Max total history storage"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Oldest unpinned items are removed when storage limit is exceeded"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Slider x:Name="MaxStorageSlider"
                                                    Style="{StaticResource SettingSliderStyle}"
                                                    Minimum="1" Maximum="50"
                                                    Value="{Binding MaxStorageGb}"
                                                    Margin="0,0,10,0" />
                                            <Border Style="{StaticResource ValueBadgeStyle}" MinWidth="52">
                                                <TextBlock FontSize="12.5" FontWeight="Medium"
                                                           Foreground="#374151"
                                                           HorizontalAlignment="Center">
                                                    <Run Text="{Binding MaxStorageGb}" /><Run Text=" GB" />
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── DUPLICATE DETECTION ── -->
                        <TextBlock Text="DUPLICATE DETECTION"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <StackPanel>
                                <!-- Collapse rapid duplicates -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Collapse rapid duplicates"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Merge repeated copies into one entry"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      IsChecked="{Binding CollapseRapidDuplicates}" />
                                    </Grid>
                                </Border>
                                <!-- Duplicate window -->
                                <Border Style="{StaticResource SettingRowLastStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Rapid duplicate window"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Time window for collapsing repeated copies"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Slider Style="{StaticResource SettingSliderStyle}"
                                                    Minimum="1" Maximum="60"
                                                    Value="{Binding RapidDuplicateWindowSeconds}"
                                                    Margin="0,0,10,0" />
                                            <Border Style="{StaticResource ValueBadgeStyle}" MinWidth="52">
                                                <TextBlock FontSize="12.5" FontWeight="Medium"
                                                           Foreground="#374151"
                                                           HorizontalAlignment="Center">
                                                    <Run Text="{Binding RapidDuplicateWindowSeconds}" /><Run Text=" sec" />
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── PRIVACY ── -->
                        <TextBlock Text="PRIVACY"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <!-- Privacy note -->
                        <Border CornerRadius="8"
                                Background="#F0FDF4"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                Padding="14,10,14,10"
                                Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒"
                                           FontSize="13"
                                           VerticalAlignment="Top"
                                           Margin="0,1,8,0" />
                                <TextBlock Text="Excluded apps are never saved to CopyTrail history."
                                           FontSize="12.5"
                                           Foreground="#166534"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <StackPanel>
                                <!-- Excluded apps list -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Excluded apps"
                                                           Style="{StaticResource SettingLabelStyle}" />
                                                <TextBlock Text="Clipboard activity from these apps is never recorded"
                                                           Style="{StaticResource SettingSubLabelStyle}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    x:Name="RemoveExclusionButton"
                                                    Style="{StaticResource ActionButtonStyle}"
                                                    Content="Remove selected"
                                                    Click="RemoveExclusionButton_Click" />
                                        </Grid>
                                        <ListBox x:Name="ExclusionListBox"
                                                 ItemsSource="{Binding ExcludedProcessNames}"
                                                 Height="110"
                                                 Background="#F9FAFB"
                                                 BorderBrush="#E5E7EB"
                                                 BorderThickness="1"
                                                 FontSize="12.5"
                                                 Foreground="#374151"
                                                 Padding="4">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="6,3,6,3" />
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                                <!-- Add exclusion -->
                                <Border Style="{StaticResource SettingRowLastStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="NewExclusionBox"
                                                 Style="{StaticResource ExclusionEntryBoxStyle}"
                                                 Margin="0,0,8,0"
                                                 ToolTip="Enter process name, e.g. MyApp or MyApp.exe" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Content="Add app"
                                                Click="AddExclusionButton_Click" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── DATA ── -->
                        <TextBlock Text="DATA"
                                   Style="{StaticResource SectionHeaderStyle}" />

                        <Border CornerRadius="10"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <StackPanel>
                                <!-- Open data folder -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Data folder"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Open the folder where CopyTrail stores its data"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ActionButtonStyle}"
                                                Click="OpenDataFolderButton_Click"
                                                Content="Open folder" />
                                    </Grid>
                                </Border>
                                <!-- Clear unpinned history -->
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Clear unpinned history"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Delete all entries except pinned items"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource DestructiveButtonStyle}"
                                                Click="ClearUnpinnedButton_Click"
                                                Content="Clear unpinned" />
                                    </Grid>
                                </Border>
                                <!-- Clear all history -->
                                <Border Style="{StaticResource SettingRowLastStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Clear all history"
                                                       Style="{StaticResource SettingLabelStyle}" />
                                            <TextBlock Text="Permanently delete all clipboard entries including pinned"
                                                       Style="{StaticResource SettingSubLabelStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource DestructiveButtonStyle}"
                                                Click="ClearHistoryButton_Click"
                                                Content="Clear all" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer separator -->
                <Rectangle Grid.Row="3" Fill="#F1F5F9" />

                <!-- ── Footer ── -->
                <Grid Grid.Row="4" Margin="24,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="ResetDefaultsButton_Click"
                            Content="Reset to defaults" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Margin="0,0,8,0"
                                Click="CancelButton_Click"
                                Content="Cancel" />
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Click="SaveButton_Click"
                                Content="Save" />
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
