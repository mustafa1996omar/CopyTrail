<Window x:Class="CopyTrail.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CopyTrail.Controls"
        xmlns:converters="clr-namespace:CopyTrail.Converters"
        xmlns:vm="clr-namespace:CopyTrail.ViewModels"
        Title="CopyTrail"
        Width="1020" Height="540"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Opacity="0">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Clean TextBox (no default chrome) -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CaretBrush" Value="#2563EB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="0" Padding="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip (unselected) -->
        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14,5,14,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Filter chip (selected) -->
        <Style x:Key="ChipSelectedStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14,5,14,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Chip text (unselected) -->
        <Style x:Key="ChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="#6B7280" />
        </Style>

        <!-- Chip text (selected) -->
        <Style x:Key="ChipTextSelectedStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Icon button -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root: transparent with margin for shadow bleed -->
    <Grid Margin="26">

        <!-- Main container: rounded white card with shadow -->
        <Border CornerRadius="16"
                Background="#FFFFFF"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="48"
                                  Direction="270"
                                  ShadowDepth="12"
                                  Opacity="0.18"
                                  Color="#0F172A" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="62" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Filter chips -->
                    <RowDefinition Height="50" />
                    <!-- Capture paused banner -->
                    <RowDefinition Height="Auto" />
                    <!-- Error banner (collapsed when no error) -->
                    <RowDefinition Height="Auto" />
                    <!-- Cards area -->
                    <RowDefinition Height="*" />
                    <!-- Separator -->
                    <RowDefinition Height="1" />
                    <!-- Footer keyboard hints -->
                    <RowDefinition Height="34" />
                </Grid.RowDefinitions>

                <!-- ── Header ── -->
                <Grid Grid.Row="0" Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <!-- Logo -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Search (fills remaining) -->
                        <ColumnDefinition Width="*" />
                        <!-- Settings button -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo mark + wordmark -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,20,0">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="#2563EB" VerticalAlignment="Center">
                            <TextBlock Text="CT"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="CopyTrail"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Search box -->
                    <Border Grid.Column="1"
                            CornerRadius="10"
                            Background="#F9FAFB"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            Padding="12,0,12,0"
                            VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="⌕"
                                       FontSize="15"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Grid Grid.Column="1">
                                <!-- Placeholder -->
                                <TextBlock x:Name="SearchPlaceholder"
                                           Text="Search clipboard history…"
                                           FontSize="13.5"
                                           Foreground="#9CA3AF"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                                <TextBox x:Name="SearchBox"
                                         Style="{StaticResource SearchBoxStyle}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="38"
                                         TextChanged="SearchBox_TextChanged" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Settings button -->
                    <Button Grid.Column="2"
                            Style="{StaticResource IconButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Settings"
                            Click="SettingsButton_Click">
                        <TextBlock Text="⚙"
                                   FontSize="16"
                                   Foreground="#6B7280" />
                    </Button>
                </Grid>

                <!-- Header separator -->
                <Rectangle Grid.Row="1" Fill="#F1F5F9" />

                <!-- ── Filter chips ── -->
                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="20,0,20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="ChipBorderAll" Style="{StaticResource ChipSelectedStyle}"
                                MouseLeftButtonUp="ChipAll_MouseUp">
                            <TextBlock x:Name="ChipTextAll" Text="All"
                                       Style="{StaticResource ChipTextSelectedStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderText" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipText_MouseUp">
                            <TextBlock x:Name="ChipTextText" Text="Text"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderLinks" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipLinks_MouseUp">
                            <TextBlock x:Name="ChipTextLinks" Text="Links"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderCode" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipCode_MouseUp">
                            <TextBlock x:Name="ChipTextCode" Text="Code"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderImages" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipImages_MouseUp">
                            <TextBlock x:Name="ChipTextImages" Text="Images"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderFiles" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipFiles_MouseUp">
                            <TextBlock x:Name="ChipTextFiles" Text="Files"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                        <Border x:Name="ChipBorderColors" Style="{StaticResource ChipStyle}"
                                MouseLeftButtonUp="ChipColors_MouseUp">
                            <TextBlock x:Name="ChipTextColors" Text="Colors"
                                       Style="{StaticResource ChipTextStyle}" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ── Capture paused indicator ── -->
                <Border x:Name="PausedBanner"
                        Grid.Row="3"
                        Background="#FFFBEB"
                        BorderBrush="#FDE68A"
                        BorderThickness="0,1,0,1"
                        Padding="20,8,20,8"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⏸"
                                   FontSize="13"
                                   Foreground="#92400E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Capture paused — new copies will not be saved"
                                   FontSize="12.5"
                                   Foreground="#92400E"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- ── Error banner (shown when paste/copy fails) ── -->
                <Border x:Name="ErrorBanner"
                        Grid.Row="4"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="0,1,0,1"
                        Padding="20,8,20,8"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠"
                                   FontSize="13"
                                   Foreground="#DC2626"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock x:Name="ErrorText"
                                   FontSize="12.5"
                                   Foreground="#DC2626"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- ── Card area ── -->
                <Grid Grid.Row="5">

                    <!-- Real cards -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="20,12,20,12"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis},
                                               ConverterParameter=Inverse}">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding Cards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ClipCardViewModel}">
                                    <controls:ClipCard Margin="0,0,12,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Loading state -->
                    <TextBlock Text="Loading…"
                               FontSize="14" Foreground="#9CA3AF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="📋"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="Copy something to see it here"
                                   FontSize="14" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                </Grid>

                <!-- Footer separator -->
                <Rectangle Grid.Row="6" Fill="#F1F5F9" />

                <!-- ── Footer: keyboard hints ── -->
                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#9CA3AF">
                        <Run FontWeight="SemiBold" Foreground="#6B7280">← →</Run>
                        <Run> Navigate  </Run>
                        <Run FontWeight="SemiBold" Foreground="#6B7280">Enter</Run>
                        <Run> Paste  </Run>
                        <Run FontWeight="SemiBold" Foreground="#6B7280">Ctrl+Enter</Run>
                        <Run> Copy only  </Run>
                        <Run FontWeight="SemiBold" Foreground="#6B7280">Ctrl+F</Run>
                        <Run> Search  </Run>
                        <Run FontWeight="SemiBold" Foreground="#6B7280">Esc</Run>
                        <Run> Dismiss</Run>
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
