<Window x:Class="CopyTrail.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CopyTrail.Controls"
        xmlns:converters="clr-namespace:CopyTrail.Converters"
        xmlns:vm="clr-namespace:CopyTrail.ViewModels"
        Title="CopyTrail"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="800" Height="240"
        Opacity="0"
        SizeToContent="Manual">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" Y="0" />
    </Window.RenderTransform>

    <Border Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,1,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Direction="90"
                              ShadowDepth="8" Opacity="0.5"
                              Color="#000000" />
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Drag handle -->
            <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="32" Height="3" CornerRadius="1.5"
                    Background="{DynamicResource HandleBrush}" />

            <!-- Header placeholder (replaced in Task 6) -->
            <ContentPresenter Grid.Row="1" x:Name="HeaderArea" />

            <!-- Paused banner -->
            <Border x:Name="PausedBanner"
                    Grid.Row="2"
                    Background="#1FFDE68A"
                    BorderBrush="#33FDE68A"
                    BorderThickness="0,1,0,1"
                    Padding="20,6,20,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏸" FontSize="12" Foreground="#92400E" Margin="0,0,8,0" />
                    <TextBlock Text="Capture paused — new copies will not be saved"
                               FontSize="12" Foreground="#92400E" />
                </StackPanel>
            </Border>

            <!-- Error banner -->
            <Border x:Name="ErrorBanner"
                    Grid.Row="3"
                    Background="#1FFB2020"
                    BorderBrush="#33FB2020"
                    BorderThickness="0,1,0,1"
                    Padding="20,6,20,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="12" Foreground="#DC2626" Margin="0,0,8,0" />
                    <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626" />
                </StackPanel>
            </Border>

            <!-- Card row placeholder (replaced in Task 6) -->
            <ContentPresenter Grid.Row="4" x:Name="CardArea" MinHeight="110" />

            <!-- Separator -->
            <Rectangle Grid.Row="5" Fill="{DynamicResource SeparatorBrush}" />

            <!-- Keyboard hints footer -->
            <StackPanel Grid.Row="6" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontSize="10.5" Foreground="{DynamicResource KbdHintForeground}">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">← →</Run>
                    <Run> Navigate  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Enter</Run>
                    <Run> Paste  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Ctrl+Enter</Run>
                    <Run> Copy only  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">P</Run>
                    <Run> Pin  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Ctrl+F</Run>
                    <Run> Search  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Esc</Run>
                    <Run> Dismiss</Run>
                </TextBlock>
            </StackPanel>

        </Grid>
    </Border>
</Window>
