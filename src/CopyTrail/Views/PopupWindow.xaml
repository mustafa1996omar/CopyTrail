<Window x:Class="CopyTrail.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CopyTrail.Controls"
        xmlns:converters="clr-namespace:CopyTrail.Converters"
        xmlns:vm="clr-namespace:CopyTrail.ViewModels"
        Title="CopyTrail"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="800" Height="240"
        Opacity="0"
        SizeToContent="Manual">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" Y="0" />
    </Window.RenderTransform>

    <Border Background="{DynamicResource PanelBackground}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="0,1,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Direction="90"
                              ShadowDepth="8" Opacity="0.5"
                              Color="#000000" />
        </Border.Effect>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="48" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <!-- Drag handle -->
            <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="32" Height="3" CornerRadius="1.5"
                    Background="{DynamicResource HandleBrush}" />

            <!-- ── Header ── -->
            <Grid Grid.Row="1" Margin="20,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6366F1" Offset="0"/>
                            <GradientStop Color="#818CF8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="CT" FontSize="9" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <!-- Search box -->
                <Border Grid.Column="1" CornerRadius="8"
                        Background="{DynamicResource SearchBackground}"
                        BorderBrush="{DynamicResource SearchBorder}"
                        BorderThickness="1" Padding="10,0,8,0"
                        VerticalAlignment="Center" Height="32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⌕" FontSize="14"
                                   Foreground="{DynamicResource SearchIcon}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Grid Grid.Column="1">
                            <TextBlock x:Name="SearchPlaceholder"
                                       Text="Search clipboard history…" FontSize="12.5"
                                       Foreground="{DynamicResource SearchPlaceholder}"
                                       VerticalAlignment="Center" IsHitTestVisible="False" />
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource BodyText}"
                                     FontSize="12.5" VerticalAlignment="Center"
                                     CaretBrush="{DynamicResource AccentPrimary}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="SearchBox_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="0" />
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                        </Grid>
                        <Button Grid.Column="2" x:Name="SearchClearButton" Content="×"
                                FontSize="15" Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource MetaText}" Padding="4,0"
                                Cursor="Hand"
                                Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}"
                                Click="SearchClearButton_Click" />
                    </Grid>
                </Border>

                <!-- Filter chips -->
                <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="10,0,0,0" VerticalAlignment="Center">
                    <StackPanel x:Name="ChipsPanel" Orientation="Horizontal">
                        <Border x:Name="ChipBorderAll" Cursor="Hand"
                                MouseLeftButtonUp="ChipAll_Click">
                            <TextBlock x:Name="ChipTextAll" Text="All" />
                        </Border>
                        <Border x:Name="ChipBorderText" Cursor="Hand"
                                MouseLeftButtonUp="ChipText_Click">
                            <TextBlock x:Name="ChipTextText" Text="Text" />
                        </Border>
                        <Border x:Name="ChipBorderLinks" Cursor="Hand"
                                MouseLeftButtonUp="ChipLinks_Click">
                            <TextBlock x:Name="ChipTextLinks" Text="Links" />
                        </Border>
                        <Border x:Name="ChipBorderCode" Cursor="Hand"
                                MouseLeftButtonUp="ChipCode_Click">
                            <TextBlock x:Name="ChipTextCode" Text="Code" />
                        </Border>
                        <Border x:Name="ChipBorderImages" Cursor="Hand"
                                MouseLeftButtonUp="ChipImages_Click">
                            <TextBlock x:Name="ChipTextImages" Text="Images" />
                        </Border>
                        <Border x:Name="ChipBorderColors" Cursor="Hand"
                                MouseLeftButtonUp="ChipColors_Click">
                            <TextBlock x:Name="ChipTextColors" Text="Colors" />
                        </Border>
                        <Border x:Name="ChipBorderFiles" Cursor="Hand"
                                MouseLeftButtonUp="ChipFiles_Click">
                            <TextBlock x:Name="ChipTextFiles" Text="Files" />
                        </Border>
                        <Border x:Name="ChipBorderPinned" Cursor="Hand"
                                MouseLeftButtonUp="ChipPinned_Click">
                            <TextBlock x:Name="ChipTextPinned" Text="📌 Pinned" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings button -->
                <Button Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" ToolTip="Settings" Click="SettingsButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="6">
                                <TextBlock Text="⚙" FontSize="15"
                                           Foreground="{DynamicResource MetaText}" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Bd"
                                                    Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                        Value="{DynamicResource ChipIdleBackground}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Normal" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Paused banner -->
            <Border x:Name="PausedBanner"
                    Grid.Row="2"
                    Background="#1FFDE68A"
                    BorderBrush="#33FDE68A"
                    BorderThickness="0,1,0,1"
                    Padding="20,6,20,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏸" FontSize="12" Foreground="#92400E" Margin="0,0,8,0" />
                    <TextBlock Text="Capture paused — new copies will not be saved"
                               FontSize="12" Foreground="#92400E" />
                </StackPanel>
            </Border>

            <!-- Error banner -->
            <Border x:Name="ErrorBanner"
                    Grid.Row="3"
                    Background="#1FFB2020"
                    BorderBrush="#33FB2020"
                    BorderThickness="0,1,0,1"
                    Padding="20,6,20,6"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="12" Foreground="#DC2626" Margin="0,0,8,0" />
                    <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#DC2626" />
                </StackPanel>
            </Border>

            <!-- ── Card row ── -->
            <Grid Grid.Row="4" MinHeight="110">

                <!-- Left scroll arrow -->
                <Button x:Name="ScrollLeftBtn" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Width="28" Background="{DynamicResource ScrollArrowBackground}"
                        BorderThickness="0" Cursor="Hand" Panel.ZIndex="10"
                        Visibility="Collapsed" Click="ScrollLeft_Click">
                    <TextBlock Text="‹" FontSize="18"
                               Foreground="{DynamicResource ScrollArrowForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>

                <!-- Right scroll arrow -->
                <Button x:Name="ScrollRightBtn" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Width="28" Background="{DynamicResource ScrollArrowBackground}"
                        BorderThickness="0" Cursor="Hand" Panel.ZIndex="10"
                        Visibility="Collapsed" Click="ScrollRight_Click">
                    <TextBlock Text="›" FontSize="18"
                               Foreground="{DynamicResource ScrollArrowForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>

                <!-- Main scroll area -->
                <ScrollViewer x:Name="CardsScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="20,12,20,12"
                              PreviewMouseWheel="CardsScrollViewer_PreviewMouseWheel"
                              ScrollChanged="CardsScrollViewer_ScrollChanged">
                    <StackPanel Orientation="Horizontal" x:Name="CardsPanel">

                        <!-- Pinned cards -->
                        <StackPanel x:Name="PinnedSection" Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPinnedCards}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ItemsControl x:Name="PinnedItemsControl" ItemsSource="{Binding PinnedCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ClipCardViewModel}">
                                        <controls:ClipCard Margin="0,0,8,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Divider between pinned and regular -->
                            <Rectangle Width="1" Margin="4,8,12,8"
                                       Fill="{DynamicResource SeparatorBrush}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRegularCards}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </StackPanel>

                        <!-- Regular (unpinned) cards -->
                        <ItemsControl x:Name="RegularItemsControl" ItemsSource="{Binding RegularCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ClipCardViewModel}">
                                    <controls:ClipCard Margin="0,0,8,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- Loading state -->
                <TextBlock Text="Loading…" FontSize="13"
                           Foreground="{DynamicResource MetaText}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <!-- Empty: no history -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📋" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Copy something to see it here" FontSize="13"
                               Foreground="{DynamicResource MetaText}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Empty: filter/search returned nothing -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFilteredEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="🔍" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="No matching clips" FontSize="13"
                               Foreground="{DynamicResource MetaText}" HorizontalAlignment="Center" />
                </StackPanel>

            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="5" Fill="{DynamicResource SeparatorBrush}" />

            <!-- Keyboard hints footer -->
            <StackPanel Grid.Row="6" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontSize="10.5" Foreground="{DynamicResource KbdHintForeground}">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">← →</Run>
                    <Run> Navigate  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Enter</Run>
                    <Run> Paste  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Ctrl+Enter</Run>
                    <Run> Copy only  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">P</Run>
                    <Run> Pin  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Ctrl+F</Run>
                    <Run> Search  </Run>
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource KbdForeground}">Esc</Run>
                    <Run> Dismiss</Run>
                </TextBlock>
            </StackPanel>

        </Grid>
    </Border>
</Window>
